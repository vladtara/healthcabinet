+        assert resp.json()["user_id"] == str(user.id)
+
+        # Old token now rejected
+        resp = await admin_client.get(
+            "/api/v1/auth/me", headers={"Authorization": f"Bearer {pre_token}"}
+        )
+        assert resp.status_code == 401
