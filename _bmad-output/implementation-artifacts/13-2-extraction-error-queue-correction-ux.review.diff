+/* ── Admin Extraction Queue ── */
+
+.hc-admin-queue-page {
+	width: 100%;
+	max-width: 1400px;
+	box-sizing: border-box;
+	padding: 24px;
+	display: flex;
+	flex-direction: column;
+	gap: 16px;
+}
+
+.hc-admin-queue-header {
+	display: flex;
+	align-items: flex-start;
+	justify-content: space-between;
+	gap: 12px;
+	flex-wrap: wrap;
+}
+
+.hc-admin-queue-title {
+	margin: 0;
+	font-size: 18px;
+	font-weight: 700;
+	color: var(--text-primary);
+}
+
+.hc-admin-queue-subtitle {
+	margin: 4px 0 0;
+	font-size: 13px;
+	color: var(--text-secondary);
+}
+
+.hc-admin-queue-count-cell {
+	text-align: center;
+	font-variant-numeric: tabular-nums;
+}
+
+.hc-admin-queue-count-concerning {
+	color: var(--status-concerning);
+	font-weight: 600;
+}
+
+.hc-admin-queue-count-action {
+	color: var(--status-action);
+	font-weight: 600;
+}
+
+.hc-admin-queue-empty-panel {
+	padding: 24px;
+	background: var(--surface-sunken);
+	box-shadow:
+		inset -1px -1px #fff,
+		inset 1px 1px #0a0a0a,
+		inset -2px -2px #dfdfdf,
+		inset 2px 2px grey;
+}
+
+.hc-admin-queue-skeleton {
+	display: flex;
+	flex-direction: column;
+	gap: 8px;
+}
+
+.hc-admin-queue-skeleton-row {
+	min-height: 40px;
+	background: var(--surface-sunken);
+	box-shadow:
+		inset -1px -1px #fff,
+		inset 1px 1px #0a0a0a,
+		inset -2px -2px #dfdfdf,
+		inset 2px 2px grey;
+	animation: hc-admin-queue-skeleton-pulse 1.5s ease-in-out infinite;
+}
+
+@media (prefers-reduced-motion: reduce) {
+	.hc-admin-queue-skeleton-row {
+		animation: none;
+		opacity: 0.85;
+	}
+}
+
+@keyframes hc-admin-queue-skeleton-pulse {
+	0%, 100% { opacity: 0.6; }
+	50% { opacity: 1; }
+}
+
+.hc-admin-queue-footer-count {
+	margin: 0;
+	font-size: 12px;
+	color: var(--text-secondary);
+}
+
+/* ── Admin Correction Detail ── */
+
+.hc-admin-correction-page {
+	width: 100%;
+	max-width: 1400px;
+	box-sizing: border-box;
+	padding: 24px;
+	display: flex;
+	flex-direction: column;
+	gap: 16px;
+}
+
+.hc-admin-correction-back-row {
+	display: flex;
+}
+
+.hc-admin-correction-header {
+	display: flex;
+	flex-direction: column;
+	gap: 4px;
+}
+
+.hc-admin-correction-title {
+	margin: 0;
+	font-size: 18px;
+	font-weight: 700;
+	color: var(--text-primary);
+}
+
+.hc-admin-correction-subtitle {
+	margin: 0;
+	font-size: 13px;
+	color: var(--text-secondary);
+}
+
+.hc-admin-correction-meta-grid {
+	display: grid;
+	grid-template-columns: repeat(4, 1fr);
+	gap: 8px 24px;
+	margin: 0;
+}
+
+.hc-admin-correction-meta-grid > div {
+	display: flex;
+	flex-direction: column;
+	gap: 2px;
+}
+
+.hc-admin-correction-meta-grid dt {
+	font-size: 12px;
+	color: var(--text-secondary);
+	text-transform: uppercase;
+	letter-spacing: 0.02em;
+}
+
+.hc-admin-correction-meta-grid dd {
+	margin: 0;
+	font-size: 14px;
+	color: var(--text-primary);
+}
+
+.hc-admin-correction-meta-grid dd.hc-admin-correction-meta-mono {
+	font-family: var(--font-mono, monospace);
+	font-size: 12px;
+	word-break: break-all;
+}
+
+.hc-admin-correction-table {
+	background: var(--surface-sunken);
+	box-shadow:
+		inset -1px -1px #fff,
+		inset 1px 1px #0a0a0a,
+		inset -2px -2px #dfdfdf,
+		inset 2px 2px grey;
+	padding: 4px;
+}
+
+.hc-admin-correction-table table {
+	width: 100%;
+	border-collapse: collapse;
+	background: var(--surface-base);
+}
+
+.hc-admin-correction-table th,
+.hc-admin-correction-table td {
+	padding: 8px 12px;
+	font-size: 13px;
+	border-bottom: 1px solid var(--border-sunken-outer);
+	vertical-align: top;
+	text-align: left;
+}
+
+.hc-admin-correction-table th {
+	font-weight: 600;
+	color: var(--text-secondary);
+	text-transform: uppercase;
+	letter-spacing: 0.02em;
+	font-size: 11px;
+	background: var(--surface-sunken);
+}
+
+.hc-admin-correction-table tbody tr:last-child td {
+	border-bottom: none;
+}
+
+.hc-admin-correction-biomarker-name {
+	font-weight: 600;
+	color: var(--text-primary);
+}
+
+.hc-admin-correction-biomarker-canonical {
+	font-size: 12px;
+	color: var(--text-secondary);
+	margin-top: 2px;
+}
+
+.hc-admin-correction-value-cell {
+	font-family: var(--font-mono, monospace);
+	text-align: right;
+	font-variant-numeric: tabular-nums;
+	white-space: nowrap;
+}
+
+.hc-admin-correction-confidence-ok {
+	font-size: 12px;
+	color: var(--text-secondary);
+}
+
+.hc-admin-correction-no-flag {
+	color: var(--text-secondary);
+}
+
+.hc-admin-correction-range-cell {
+	font-size: 12px;
+	color: var(--text-secondary);
+	text-align: center;
+	white-space: nowrap;
+}
+
+.hc-admin-correction-success {
+	display: flex;
+	align-items: center;
+	gap: 6px;
+	font-size: 13px;
+	font-weight: 600;
+	color: var(--status-optimal);
+}
+
+.hc-admin-correction-form {
+	display: flex;
+	flex-direction: column;
+	gap: 6px;
+}
+
+.hc-admin-correction-form-row {
+	display: flex;
+	gap: 6px;
+	flex-wrap: wrap;
+}
+
+.hc-admin-correction-input-value.hc-input {
+	width: 90px;
+}
+
+.hc-admin-correction-input-reason.hc-input {
+	width: 200px;
+}
+
+.hc-admin-correction-field-error {
+	margin: 0;
+	font-size: 12px;
+	color: var(--status-action);
+}
+
+.hc-admin-correction-row-highlight {
+	background: color-mix(in srgb, var(--accent) 8%, transparent);
+	box-shadow: inset 3px 0 0 var(--accent);
+}
+
+.hc-admin-correction-skeleton {
+	display: flex;
+	flex-direction: column;
+	gap: 8px;
+}
+
+.hc-admin-correction-skeleton-row {
+	min-height: 40px;
+	background: var(--surface-sunken);
+	box-shadow:
+		inset -1px -1px #fff,
+		inset 1px 1px #0a0a0a,
+		inset -2px -2px #dfdfdf,
+		inset 2px 2px grey;
+	animation: hc-admin-correction-skeleton-pulse 1.5s ease-in-out infinite;
+}
+
+@media (prefers-reduced-motion: reduce) {
+	.hc-admin-correction-skeleton-row {
+		animation: none;
+		opacity: 0.85;
+	}
+}
+
+@keyframes hc-admin-correction-skeleton-pulse {
+	0%, 100% { opacity: 0.6; }
+	50% { opacity: 1; }
+}
