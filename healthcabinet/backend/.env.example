# Application
ENVIRONMENT=development
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=

# Refresh-cookie flags. Production (HTTPS) keeps defaults: Secure=true + SameSite=strict.
# Plain-HTTP dev (docker-compose, non-localhost preview) must set COOKIE_SECURE=false;
# browsers drop Secure cookies on non-secure origins. SameSite=none requires Secure=true.
# COOKIE_SECURE=true
# COOKIE_SAMESITE=strict

# Database
DATABASE_URL=postgresql+asyncpg://healthcabinet:healthcabinet@localhost:5432/healthcabinet

# Optional local/dev bootstrap admin. When both are set, backend startup ensures the
# account exists, promotes it to role=admin, and reactivates it if suspended.
# Existing passwords are not overwritten for pre-existing accounts.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# AWS (eu-central-1 ONLY — health data never leaves EU)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
AWS_S3_BUCKET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Anthropic
ANTHROPIC_API_KEY=
AI_CHAT_MODEL=claude-sonnet-4-6

# Sentry
SENTRY_DSN=

# Redis
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173","http://127.0.0.1:4173"]
